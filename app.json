{
  "expo": {
    "name": "Peniel Church",
    "slug": "PenielChurchApp",
    "scheme": "penielchurch",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1740"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.uk.penielchurch.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Usado para atualizar sua foto de perfil.",
        "NSPhotoLibraryUsageDescription": "Usado para selecionar sua foto de perfil.",
        "NSUserNotificationsUsageDescription": "Receba notificações de aniversários e avisos da igreja.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1740"
      },
      "package": "org.uk.penielchurch.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A1740",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f53e9e07-9556-4ea8-80e0-da4487b38e56"
      }
    }
  }
}
